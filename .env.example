# Supabase Configuration (Required)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# Google Gemini AI (Required — powers AI Crowd Advisor & Smart Announcements)
VITE_GEMINI_API_KEY="your-gemini-api-key"

# App URL (For Vercel, this is usually https://your-app.vercel.app or auto-detected)
APP_URL="http://localhost:3000"

# Google Analytics (Required — powers behavioral metrics & reporting)
VITE_GA_MEASUREMENT_ID="G-MH0EP6E25W"

# Google Maps Embed API (Free — Unlimited requests)
VITE_GOOGLE_MAPS_API_KEY="your-maps-embed-api-key"

# Firebase Cloud Messaging (Free — Unlimited push notifications)
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_PROJECT_ID="your-firebase-project-id"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-firebase-app-id"
VITE_FIREBASE_VAPID_KEY="your-vapid-key"

# Firebase Project ID (server-side — for FCM HTTP v1 API)
FIREBASE_PROJECT_ID="your-firebase-project-id"

# Google Service Account Key (Vercel Secret)
# Paste your Firebase service account JSON here as a single-line string for Vercel env
GOOGLE_SERVICE_ACCOUNT_KEY='{"type": "service_account", ...}'

# Google Forms Incident Reporting
VITE_INCIDENT_FORM_URL="https://docs.google.com/forms/d/e/1FAIpQLSd3_cNSboupURYhs4qQ9CYdghaLjSHso8nIevY-vYr0BbApuA/formResponse"
VITE_FORM_ENTRY_GATE_ID="entry.746314850"
VITE_FORM_ENTRY_EVENT_ID="entry.750162853"
VITE_FORM_ENTRY_ISSUE_TYPE="entry.1774766417"
